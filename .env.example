# SMB Audit Engine — environment variables
# Copy to .env for local dev. In production (Render), set these in the dashboard.

NODE_ENV=production
PORT=5000

# Where data.db and uploaded Manus PDFs live.
# Local dev: leave unset (defaults to project root).
# Render: /var/data (mounted persistent disk — see render.yaml).
DATA_DIR=/var/data

# Auth gate
AUTH_ENABLED=true
ALLOWED_EMAILS=smbsolutions00@gmail.com
APP_URL=https://audit.smbsolution.ai

# 32+ char random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=replace-me-with-a-long-random-string

# Resend (https://resend.com) — for magic-link emails.
# For initial testing you can use onboarding@resend.dev as AUTH_FROM_EMAIL.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
AUTH_FROM_EMAIL=SMB Audit <noreply@smbsolution.ai>

# Anthropic Claude — for audit report generation
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
